<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{pageTitle}}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Macondo&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
    <link rel="stylesheet" href="../styles/style.css">
</head>

<body>
    <main class="container">
        <header class="page-header">
            <h1>{{pageTitle}}</h1>
            <nav class="breadcrumb">
              <ul>
                <li>Fire Emblem Fates</li>
                <li><a href="{{indexHref}}">Character Guides</a></li>
                <li>{{characterName}}</li>
              </ul>
            </nav>
        </header>

        {{#if isCorrinKana}}
        <section class="control-stack" aria-label="Class Talent selector">
            <label for="class-talent">Class Talent</label>
            <select id="class-talent" name="class-talent">
                {{#each talentOptions}}
                <option value="{{key}}" {{#if selected}} selected{{/if}}>{{name}}</option>
                {{/each}}
            </select>
        </section>
        {{/if}}

        {{#if isChild}}
        <section class="control-stack" aria-label="Parent selector">
            <label for="parent-select">Parent</label>
            <select id="parent-select" name="parent-select">
                <option value="-none-">- None -</option>
                {{#each parentOptions}}
                <option value="{{key}}">{{displayName}}</option>
                {{/each}}
            </select>
        </section>
        {{/if}}

        <section>
            <h2 class="section-title">Default Classes and Skills</h2>
            <div class="three-column-grid">
                {{#each defaultPanels}}
                {{> class-panel}}
                {{/each}}
                {{#if isCorrinKana}}
                  {{#each heartSealTalentPanels}}
                  {{> class-panel}}
                  {{/each}}
                {{/if}}
                {{#if isChild}}
                  <article class="panel" data-group="parent-panel" data-key="-none-">
                      <header>
                          <h3>Heart Seal - Variable Parent</h3>
                      </header>
                      <section class="class-block">
                          <div>(Select a parent)</div>
                      </section>
                  </article>
                  {{#each parentPanels}}
                  {{> class-panel}}
                  {{/each}}
                {{/if}}
            </div>
        </section>

        {{#if hasSealSection}}
        <section class="cards-grid">
            <h2 class="section-title">Friendship/Partner Seal Classes and Skills</h2>
            <div class="two-column-grid">
                {{#if hasFriendship}}
                <div>
                    <div class="selector-group">
                        <label for="friendship-support">Friendship Seal (A+)</label>
                        <select id="friendship-support" name="friendship-support">
                            <option value="-none-">- None -</option>
                            {{#each friendshipOptions}}
                            <option value="{{key}}">{{displayName}}</option>
                            {{/each}}
                        </select>
                    </div>
                    <article class="panel" data-group="friendship-panel" data-key="-none-">
                        <header>
                            <h3>Friendship Seal</h3>
                        </header>
                        <section class="class-block">
                            <div>(Select an A+ rank support partner)</div>
                        </section>
                    </article>
                    {{#each friendshipPanels}}
                    {{#if isCorrinKana}}
                    <div data-group="friendship-panel" data-key="{{panelKey}}" hidden>
                        <div class="selector-group">
                            <label for="friendship-talent-{{panelKey}}">Class Talent</label>
                            <select id="friendship-talent-{{panelKey}}" name="friendship-talent-{{panelKey}}">
                                {{#each talentOptions}}
                                <option value="{{key}}" {{#if selected}} selected{{/if}}>{{name}}</option>
                                {{/each}}
                            </select>
                        </div>
                        {{#each talentPanels}}
                        {{> class-panel}}
                        {{/each}}
                    </div>
                    {{else}}
                    {{> class-panel}}
                    {{/if}}
                    {{/each}}
                </div>
                {{/if}}
                {{#if hasPartner}}
                <div>
                    <div class="selector-group">
                        <label for="partner-support">Partner Seal (S)</label>
                        <select id="partner-support" name="partner-support">
                            <option value="-none-">- None -</option>
                            {{#each partnerOptions}}
                            <option value="{{key}}">{{displayName}}</option>
                            {{/each}}
                        </select>
                    </div>
                    <article class="panel" data-group="partner-panel" data-key="-none-">
                        <header>
                            <h3>Partner Seal</h3>
                        </header>
                        <section class="class-block">
                            <div>(Select an S rank support partner)</div>
                        </section>
                    </article>
                    {{#each partnerPanels}}
                    {{#if isCorrinKana}}
                    <div data-group="partner-panel" data-key="{{panelKey}}" hidden>
                        <div class="selector-group">
                            <label for="partner-talent-{{panelKey}}">Class Talent</label>
                            <select id="partner-talent-{{panelKey}}" name="partner-talent-{{panelKey}}">
                                {{#each talentOptions}}
                                <option value="{{key}}" {{#if selected}} selected{{/if}}>{{name}}</option>
                                {{/each}}
                            </select>
                        </div>
                        {{#each talentPanels}}
                        {{> class-panel}}
                        {{/each}}
                    </div>
                    {{else}}
                    {{> class-panel}}
                    {{/if}}
                    {{/each}}
                </div>
                {{/if}}
            </div>
        </section>
        {{/if}}
    </main>

    <script>window.PAGE_CONFIG={{{json pageConfig}}};</script>
    <script src="../scripts/seal-ui.js"></script>
</body>

</html>