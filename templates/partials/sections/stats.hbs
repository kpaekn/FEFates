<header>
  <h2>Growth Rate and Base Stats (Work in Progress)</h2>
</header>

<section class="sgc">
  <div class="sg">
    <select id="class-change-options">
      {{#each classChangeOptions}}
      <option value="{{key}}" {{#if selected}}selected{{/if}}>{{name}}</option>
      {{/each}}
    </select>
  </div>
</section>

<table id="growths-table" class="table">
  <thead>
    <tr>
      <th>Growth</th>
      <th></th>
      {{#each statsData.labels.growth}}
      <th>{{label}}</th>
      {{/each}}
    </tr>
  </thead>
  <tbody>
    <tr>
      <td><strong>Base</strong></td>
      <td></td>
      {{#each statsData.labels.growth}}
      <td>{{lookup @root.statsData.growth key}}</td>
      {{/each}}
    </tr>
    {{#each classChangeOptions as |class|}}
    <tr data-class-key="{{key}}" class="class-growths-row" {{#if hidden}}hidden{{/if}}>
      <td><strong>{{name}}</strong></td>
      <td></td>
      {{#each @root.statsData.labels.growth}}
      <td data-key="{{key}}">{{add-stats key @root.statsData.growth class.stats.growth}}</td>
      {{/each}}
    </tr>
    {{/each}}
  </tbody>
</table>

{{#each statsData.base as |labeledBaseStats|}}
<table id="stats-table-{{@index}}" class="table stats-table">
  <thead>
    <tr>
      <th>Base Stats</th>
      {{#each @root.statsData.labels.base}}
      <th>{{label}}</th>
      {{/each}}
    </tr>
  </thead>
  <tbody>
    <tr>
      <td><strong>{{labeledBaseStats.label}}</strong></td>
      {{#each @root.statsData.labels.base}}
      <td>{{lookup labeledBaseStats.stats key}}</td>
      {{/each}}
    </tr>
    {{#each @root.classChangeOptions as |class|}}
    <tr data-class-key="{{key}}" class="class-stats-row" {{#if hidden}}hidden{{/if}}>
      <td><strong>{{name}}</strong></td>
      <td>-</td>
      {{#each @root.statsData.labels.growth}}
      <td data-key="{{key}}">{{add-stats key labeledBaseStats.stats class.stats.base}}</td>
      {{/each}}
    </tr>
    {{/each}}
  </tbody>
</table>
{{/each}}

{{!-- Legacy --}}
<div class="three-column-grid">
  <div class="two-span-column">
    <table class="table">
      <thead>
        <tr>
          <th>Growth Rates</th>
          {{#each growthRates}}
          <th>{{stat}}</th>
          {{/each}}
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="row-label">Base</td>
          {{#each growthRates}}
          <td{{#if ../isCorrin}} data-base-growth-idx="{{@index}}"{{/if}}>{{value}}%</td>
          {{/each}}
        </tr>
        <tr id="class-growth-row">
          <td class="row-label select-container">
            <select id="class-growth-select" name="class-growth-select">
              {{#each classGrowthOptions}}
              <option value="{{key}}" {{#if selected}} selected{{/if}}>{{name}}</option>
              {{/each}}
            </select>
          </td>
          {{#each growthRates}}
          <td data-class-growth-idx="{{@index}}"></td>
          {{/each}}
        </tr>
      </tbody>
    </table>
    <table class="table">
      <thead>
        <tr>
          <th>Base Stats</th>
          {{#each baseStatsHeaders}}
          <th>{{this}}</th>
          {{/each}}
        </tr>
      </thead>
      <tbody>
        {{#if baseStatsRows}}
        {{#each baseStatsRows}}
        <tr>
          <td class="row-label">{{label}}</td>
          <td>{{level}}</td>
          <td{{#if ../isCorrin}} data-base-stat-row="{{@index}}" data-base-stat-idx="0"{{/if}}>{{hp}}</td>
          <td{{#if ../isCorrin}} data-base-stat-row="{{@index}}" data-base-stat-idx="1"{{/if}}>{{str}}</td>
          <td{{#if ../isCorrin}} data-base-stat-row="{{@index}}" data-base-stat-idx="2"{{/if}}>{{mag}}</td>
          <td{{#if ../isCorrin}} data-base-stat-row="{{@index}}" data-base-stat-idx="3"{{/if}}>{{skl}}</td>
          <td{{#if ../isCorrin}} data-base-stat-row="{{@index}}" data-base-stat-idx="4"{{/if}}>{{spd}}</td>
          <td{{#if ../isCorrin}} data-base-stat-row="{{@index}}" data-base-stat-idx="5"{{/if}}>{{lck}}</td>
          <td{{#if ../isCorrin}} data-base-stat-row="{{@index}}" data-base-stat-idx="6"{{/if}}>{{def}}</td>
          <td{{#if ../isCorrin}} data-base-stat-row="{{@index}}" data-base-stat-idx="7"{{/if}}>{{res}}</td>
        </tr>
        {{/each}}
        {{/if}}
      </tbody>
    </table>
  </div>
</div>