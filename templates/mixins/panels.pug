mixin panelGroup(panels)
  each panel in panels
    article.panel(data-group=panel.group, data-key=panel.key, hidden=panel.hidden)
      h3= panel.label
      if panel.placeholder
        section.class-block
          div= panel.placeholder

      if panel.cls
        +clsPanelBlock(panel.cls)
        if panel.cls.promotion
          each promoCls in panel.cls.promotion
            +clsPanelBlock(promoCls)

mixin clsPanelBlock(cls)
  section.class-block
    .class-heading
      h3= cls.name
      each weapon in cls.weapons || []
        img.weapon-icon(src=weaponIconPath(weapon), alt=weapon)
    .skill-list
      each skill in cls.skills || []
        .skill-row
          img.skill-icon(src=skillIconPath(skill.key), alt=skill.name)
          .skill-copy
            strong= skill.name
            span= skill.description
